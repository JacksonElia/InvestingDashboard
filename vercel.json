{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "/api/stock-price"
  },
  "rewrites": [
    {
      "source": "/api/stock-price",
      "destination": "/api/stock-price.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
